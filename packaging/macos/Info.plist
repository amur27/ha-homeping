<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Шаблон Info.plist для бандла HomePing.app (task-10).
  Логика файла: метаданные приложения macOS; __VERSION__ заменяется
  на версию из git describe скриптом scripts/package-macos.sh.
  LSUIElement=true — агент живёт только в строке меню, без иконки в доке.
-->
<plist version="1.0">
<dict>
    <key>CFBundleName</key><string>HomePing</string>
    <key>CFBundleDisplayName</key><string>HomePing</string>
    <key>CFBundleIdentifier</key><string>com.github.amur27.homeping</string>
    <key>CFBundleExecutable</key><string>homeping</string>
    <key>CFBundlePackageType</key><string>APPL</string>
    <key>CFBundleIconFile</key><string>icon</string>
    <key>CFBundleShortVersionString</key><string>__VERSION__</string>
    <key>CFBundleVersion</key><string>__VERSION__</string>
    <key>LSMinimumSystemVersion</key><string>12.0</string>
    <key>LSUIElement</key><true/>
    <key>NSHighResolutionCapable</key><true/>
</dict>
</plist>
